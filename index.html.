<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DEDIK AI - Premium Digital Store</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-zinc-950 text-zinc-50 min-h-screen flex flex-col justify-between">

    <header class="border-b border-zinc-800/80 backdrop-blur-md sticky top-0 z-50 bg-zinc-950/70">
        <div class="max-w-5xl mx-auto px-4 py-4 flex justify-between items-center">
            <h1 class="text-xl font-black tracking-wider bg-gradient-to-r from-emerald-400 to-teal-500 bg-clip-text text-transparent">DEDIK AI</h1>
            <span class="text-xs font-semibold bg-zinc-800 text-zinc-400 px-2.5 py-1 rounded-full border border-zinc-700">Autopilot System v2.6</span>
        </div>
    </header>

    <main class="max-w-5xl mx-auto px-4 py-12 flex-grow w-full">
        <div class="text-center mb-12">
            <h2 class="text-3xl font-extrabold tracking-tight sm:text-4xl mb-3">AI Assets Catalog</h2>
            <p class="text-zinc-400 text-sm max-w-md mx-auto">Produk digital premium hasil riset robot AI, siap pakai untuk meningkatkan produktivitas Anda.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            
            <div class="bg-zinc-900/50 border border-zinc-800 rounded-2xl p-6 flex flex-col justify-between hover:border-emerald-500/50 transition-all duration-300">
                <div>
                    <div class="flex justify-between items-start mb-4">
                        <span class="text-[10px] uppercase font-bold tracking-widest bg-emerald-500/10 text-emerald-400 px-2 py-0.5 rounded border border-emerald-500/20">AI Design</span>
                        <span class="text-sm font-semibold text-zinc-400">Rp 129.000</span>
                    </div>
                    <h3 class="text-lg font-bold text-zinc-100 mb-2">50+ Premium Prompt Interior Minimalis</h3>
                    <p class="text-zinc-400 text-xs leading-relaxed mb-4">Koleksi prompt terstruktur untuk menghasilkan render desain ruangan estetik, furnitur modern, dan pencahayaan sinematik yang siap dijual ke klien.</p>
                </div>
                <button onclick="openCheckout('prod_001')" class="w-full bg-gradient-to-r from-emerald-500 to-teal-600 hover:from-emerald-400 hover:to-teal-500 text-zinc-950 text-xs font-bold py-3 px-4 rounded-xl transition-all duration-200 text-center shadow-lg shadow-emerald-500/10">
                    Beli & Download Instan
                </button>
            </div>

            <div class="bg-zinc-900/50 border border-zinc-800 rounded-2xl p-6 flex flex-col justify-between hover:border-teal-500/50 transition-all duration-300">
                <div>
                    <div class="flex justify-between items-start mb-4">
                        <span class="text-[10px] uppercase font-bold tracking-widest bg-teal-500/10 text-teal-400 px-2 py-0.5 rounded border border-teal-500/20">AI Copywriting</span>
                        <span class="text-sm font-semibold text-zinc-400">Rp 89.000</span>
                    </div>
                    <h3 class="text-lg font-bold text-zinc-100 mb-2">Master Script Copywriting Penjualan</h3>
                    <p class="text-zinc-400 text-xs leading-relaxed mb-4">Formula prompt teks untuk memaksa AI membuat penawaran produk yang persuasif, script iklan video pendek, dan hook medsos yang memicu konversi tinggi.</p>
                </div>
                <button onclick="openCheckout('prod_002')" class="w-full bg-zinc-800 hover:bg-zinc-700 text-zinc-100 text-xs font-bold py-3 px-4 rounded-xl transition-all duration-200 text-center border border-zinc-700">
                    Beli & Download Instan
                </button>
            </div>

        </div>
    </main>

    <footer class="border-t border-zinc-900 bg-zinc-950 py-6 text-center">
        <p class="text-[11px] text-zinc-600">&copy; 2026 DEDIK AI. All rights reserved. Secured by Lynk.id & Vercel.</p>
    </footer>

    <script>
        function openCheckout(productId) {
            // JALUR KASIR OTOMATIS
            const links = {
                // Tempel link produk Lynk.id Anda di bawah ini:
                "prod_001": "https://lynk.id/", // Ganti dengan link Lynk.id produk Interior Anda
                "prod_002": "https://lynk.id/"  // Ganti dengan link Lynk.id produk Copywriting Anda
            };

            const targetLink = links[productId];
            
            if (targetLink && targetLink !== "https://lynk.id/") {
                window.open(targetLink, '_blank');
            } else {
                alert("Sistem Pembayaran Sedang Disiapkan oleh Robot. Silakan Cek Beberapa Saat Lagi!");
            }
        }
    </script>
</body>
</html>
